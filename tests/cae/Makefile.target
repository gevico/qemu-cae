# -*- Mode: makefile -*-
#
# CAE (Cycle Approximate Engine) test framework
#
# Runs from $BUILD_DIR/tests/cae/$TARGET/ (copied there by meson).
# Includes config-host.mak and config-target.mak generated by
# configure, which provide SRC_PATH, QEMU, CC, etc.
#
# Three test modes per architecture:
#   Makefile.target          - user-mode tests
#   Makefile.softmmu-target  - system-mode tests (qemu-system-* -accel cae)
#   Makefile.difftest-target - difftest (CAE vs gem5 IPC comparison)

all:
-include ../config-host.mak
-include config-target.mak

# BUILD_DIR is the top-level build directory (parent of tests/)
BUILD_DIR := $(abspath $(CURDIR)/../../..)

COMMA := ,
NULL :=
SPACE := $(NULL) #

quiet-command = $(if $(V),$1,$(if $(2),@printf "  %-7s %s\n" $2 $3 && $1, @$1))

# Architecture name
ARCH = $(TARGET_NAME)

# Export for sub-makefiles and scripts
export SRC_PATH
export CAE_BUILD_DIR := $(BUILD_DIR)
export QEMU

# Benchmarks cross-compiler (from config-target.mak or fallback)
RISCV_CC ?= $(CC)

# Test lists populated by arch-specific includes
USER_TESTS =
SYSTEM_TESTS =
DIFFTEST_BENCHMARKS =

-include $(SRC_PATH)/tests/cae/$(ARCH)/Makefile.target
-include $(SRC_PATH)/tests/cae/$(ARCH)/Makefile.softmmu-target
-include $(SRC_PATH)/tests/cae/$(ARCH)/Makefile.difftest-target

all: $(USER_TESTS) $(SYSTEM_TESTS)

.PHONY: run run-user run-system run-difftest build-difftest clean

run: run-user run-system

clean:
	rm -f $(USER_TESTS) $(SYSTEM_TESTS) *.o *.elf
