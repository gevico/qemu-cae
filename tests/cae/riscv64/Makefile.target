# instrumentation. These test instruction classification and basic
# timing without requiring a full machine model.

VPATH += $(SRC_PATH)/tests/cae/riscv64

# User-mode tests (placeholder for future user-mode CAE support)
USER_TESTS =

run-user:
	@echo "CAE riscv64 user-mode tests: none defined yet"
