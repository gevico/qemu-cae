diff --git a/src/utils/itrace_binary.c b/src/utils/itrace_binary.c
new file mode 100644
index 00000000..3fafdbc2
--- /dev/null
+++ b/src/utils/itrace_binary.c
@@ -0,0 +1,257 @@
+/*
+ * CAE-side difftest binary-itrace emitter for NEMU.
+ *
+ * On-disk layout matches include/cae/trace.h in the cae-qemu repo
+ * exactly. Two modes are supported:
+ *   * ITRACE_MODE_TRACE      (0): 40-byte CaeTraceRecord per retire.
+ *   * ITRACE_MODE_CHECKPOINT (1): 608-byte CaeTraceCheckpointRecord
+ *                                 every CAE_TRACE_CHECKPOINT_INTERVAL
+ *                                 (1 000 000) retires — tier-2 path.
+ *
+ * scripts/nemu-difftest.py byte-compares two such files and rejects
+ * any header mismatch before inspecting records, so the field widths
+ * and offsets here MUST stay frozen alongside the consumer.
+ *
+ * Introduced by tools/nemu-itrace.patch in cae-qemu; guarded by
+ * CONFIG_ITRACE_BINARY and a NULL --itrace-out=<path> argument so
+ * an unconfigured / unpassed build is a no-op in the hot path.
+ */
+
+#include <stdio.h>
+#include <string.h>
+#include <utils.h>
+#include <cpu/cpu.h>
+#include <isa.h>                 /* extern CPU_state cpu; */
+#include <memory/paddr.h>
+
+#define ITRACE_MODE_TRACE      0u
+#define ITRACE_MODE_CHECKPOINT 1u
+
+#define ITRACE_TRACE_RING_NR 256
+#define ITRACE_TRACE_REC_SZ   40
+#define ITRACE_CP_REC_SZ     608
+#define ITRACE_HDR_SZ         16
+
+#define ITRACE_CP_INTERVAL   1000000ULL  /* CAE_TRACE_CHECKPOINT_INTERVAL_DEFAULT */
+#define ITRACE_CP_MEM_BYTES  0x100000ULL /* 1 MiB guest-memory window hashed */
+
+/* Matches CAE_TRACE_* constants in cae-qemu include/cae/trace.h. */
+#define ITRACE_MAGIC         0x49454143u   /* 'CAEI' little-endian */
+#define ITRACE_VERSION       1u
+#define ITRACE_ENDIAN_LITTLE 1u
+#define ITRACE_ISA_RV64GC    (1u << 0)
+
+static FILE *itrace_fp;
+static uint8_t itrace_mode;
+static uint8_t itrace_ring[ITRACE_TRACE_RING_NR][ITRACE_TRACE_REC_SZ];
+static size_t itrace_ring_nr;
+static uint64_t itrace_retire_count;
+
+static inline void le16(uint8_t *p, uint16_t v)
+{
+    p[0] = (uint8_t)(v);
+    p[1] = (uint8_t)(v >> 8);
+}
+
+static inline void le32(uint8_t *p, uint32_t v)
+{
+    le16(p, (uint16_t)v);
+    le16(p + 2, (uint16_t)(v >> 16));
+}
+
+static inline void le64(uint8_t *p, uint64_t v)
+{
+    le32(p, (uint32_t)v);
+    le32(p + 4, (uint32_t)(v >> 32));
+}
+
+/*
+ * FNV-1a 64-bit hash over a bounded guest-memory window. Must use
+ * the same offset+width as the CAE-side hash in
+ * target/riscv/cae/cae-riscv-checkpoint.c so the checkpoint
+ * byte-diff has a meaningful memory_hash column. guest_to_host()
+ * returns NULL when `start` is outside the mapped window, in which
+ * case we return the FNV offset basis unchanged (a zero-byte
+ * stream hashes to the basis, which matches CAE's "unmapped reads
+ * as 0" contract).
+ */
+static uint64_t itrace_memory_hash_fnv1a(uint64_t start, uint64_t nbytes)
+{
+    const uint64_t FNV_OFFSET = 0xcbf29ce484222325ULL;
+    const uint64_t FNV_PRIME  = 0x100000001b3ULL;
+    uint64_t h = FNV_OFFSET;
+    const uint8_t *base = (const uint8_t *)guest_to_host(start);
+    if (base == NULL) {
+        return h;
+    }
+    for (uint64_t i = 0; i < nbytes; i++) {
+        h ^= (uint64_t)base[i];
+        h *= FNV_PRIME;
+    }
+    return h;
+}
+
+void nemu_itrace_flush(void)
+{
+    IFNDEF(CONFIG_ITRACE_BINARY, return);
+    if (itrace_fp == NULL) {
+        return;
+    }
+    if (itrace_mode == ITRACE_MODE_TRACE && itrace_ring_nr != 0) {
+        fwrite(itrace_ring, ITRACE_TRACE_REC_SZ, itrace_ring_nr,
+               itrace_fp);
+        itrace_ring_nr = 0;
+    }
+    fflush(itrace_fp);
+
+    /*
+     * AC-K-3.1 exact retired-insn count. run-nemu-ref.sh
+     * captures this line from stderr and records it in
+     * nemu-itrace-stats.json so the suite's count gate can
+     * compare exact values rather than inferring from
+     * checkpoint-file size (which loses up to one interval of
+     * precision).
+     */
+    fprintf(stderr, "NEMU-ITRACE-FINAL-COUNT: %lu\n",
+            (unsigned long)itrace_retire_count);
+}
+
+void init_nemu_itrace_binary(const char *path, uint8_t mode)
+{
+    uint8_t hdr[ITRACE_HDR_SZ];
+    uint16_t rec_sz;
+
+    IFNDEF(CONFIG_ITRACE_BINARY, return);
+    if (path == NULL) {
+        return;
+    }
+    itrace_fp = fopen(path, "wb");
+    Assert(itrace_fp, "Can not open '%s' for binary itrace", path);
+    itrace_mode = mode;
+    itrace_retire_count = 0;
+
+    rec_sz = (mode == ITRACE_MODE_CHECKPOINT)
+           ? (uint16_t)ITRACE_CP_REC_SZ
+           : (uint16_t)ITRACE_TRACE_REC_SZ;
+
+    /* 16-byte CaeTraceHeader: magic / version / endianness / mode /
+     * record_size / reserved / isa_subset. Must match cae-qemu. */
+    memset(hdr, 0, sizeof(hdr));
+    le32(hdr + 0,  ITRACE_MAGIC);
+    le16(hdr + 4,  ITRACE_VERSION);
+    hdr[6] = ITRACE_ENDIAN_LITTLE;
+    hdr[7] = itrace_mode;
+    le16(hdr + 8,  rec_sz);
+    le16(hdr + 10, 0);                      /* reserved */
+    le32(hdr + 12, ITRACE_ISA_RV64GC);
+    fwrite(hdr, 1, sizeof(hdr), itrace_fp);
+}
+
+/*
+ * Tier-2 checkpoint record writer (608 bytes, little-endian,
+ * matches CaeTraceCheckpointRecord in cae-qemu include/cae/trace.h):
+ *   retire_index u64   @  0
+ *   pc          u64   @  8
+ *   gpr[32]     u64*32 @ 16
+ *   fpr[32]     u64*32 @ 272
+ *   csrs[8]     u64*8  @ 528
+ *   memory_hash u64   @ 592
+ *   flags       u32   @ 600
+ *   reserved    u32   @ 604
+ *
+ * CSR ordering matches target/riscv/cae/cae-riscv-checkpoint.c:
+ *   csrs[0] = frm                 — derived from fcsr[7:5]
+ *   csrs[1] = fflags              — derived from fcsr[4:0]
+ *   csrs[2] = fcsr                — combined (frm<<5 | fflags)
+ *   csrs[3] = mstatus
+ *   csrs[4] = mepc
+ *   csrs[5] = mcause
+ *   csrs[6] = mie
+ *   csrs[7] = priv                — NEMU's cpu.mode
+ * Members come from NEMU's riscv64 isa-def.h cpu struct. A
+ * divergent CSR value on either side shows up as a byte-diff
+ * mismatch at the next checkpoint.
+ */
+static void nemu_itrace_checkpoint_emit(uint64_t pc)
+{
+    uint8_t rec[ITRACE_CP_REC_SZ];
+    memset(rec, 0, sizeof(rec));
+
+    le64(rec + 0, itrace_retire_count);
+    le64(rec + 8, pc);
+    for (unsigned i = 0; i < 32; i++) {
+        le64(rec + 16 + i * 8, cpu.gpr[i]._64);
+    }
+#ifdef CONFIG_FPU_SOFT
+    for (unsigned i = 0; i < 32; i++) {
+        le64(rec + 272 + i * 8, cpu.fpr[i]._64);
+    }
+#endif
+#ifdef CONFIG_ISA_riscv64
+    {
+        uint64_t fcsr   = cpu.fcsr;
+        uint64_t frm    = (fcsr >> 5) & 7u;
+        uint64_t fflags = fcsr & 0x1fu;
+        le64(rec + 528 + 0 * 8, frm);
+        le64(rec + 528 + 1 * 8, fflags);
+        le64(rec + 528 + 2 * 8, fcsr);
+        le64(rec + 528 + 3 * 8, cpu.mstatus);
+        le64(rec + 528 + 4 * 8, cpu.mepc);
+        le64(rec + 528 + 5 * 8, cpu.mcause);
+        le64(rec + 528 + 6 * 8, cpu.mie);
+        le64(rec + 528 + 7 * 8, cpu.mode);
+    }
+#endif
+    le64(rec + 592, itrace_memory_hash_fnv1a(CONFIG_MBASE,
+                                              ITRACE_CP_MEM_BYTES));
+    /* flags = 0, reserved = 0; zeroed by memset. */
+
+    fwrite(rec, 1, sizeof(rec), itrace_fp);
+    fflush(itrace_fp);
+}
+
+void nemu_itrace_emit(uint64_t pc, uint32_t opcode, uint8_t rd_idx,
+    uint64_t rd_val, uint64_t mem_addr, uint16_t mem_size,
+    uint64_t mem_val, uint8_t flags)
+{
+    uint8_t *rec;
+
+    IFNDEF(CONFIG_ITRACE_BINARY, return);
+    if (itrace_fp == NULL) {
+        return;
+    }
+
+    itrace_retire_count++;
+
+    if (itrace_mode == ITRACE_MODE_CHECKPOINT) {
+        /*
+         * Tier-2: per-retire trace records are dropped; only the
+         * periodic checkpoint snapshot is emitted. This keeps
+         * tier-2 trace volume bounded (tens of KiB per 10M-insn
+         * run vs. tens of MiB at 40 B/retire).
+         */
+        if ((itrace_retire_count % ITRACE_CP_INTERVAL) == 0) {
+            nemu_itrace_checkpoint_emit(pc);
+        }
+        (void)opcode; (void)rd_idx; (void)rd_val;
+        (void)mem_addr; (void)mem_size; (void)mem_val; (void)flags;
+        return;
+    }
+
+    /* Trace mode: ring-buffered 40-byte records. */
+    if (itrace_ring_nr == ITRACE_TRACE_RING_NR) {
+        nemu_itrace_flush();
+    }
+    rec = itrace_ring[itrace_ring_nr++];
+
+    /* 40-byte CaeTraceRecord: pc(8) opcode(4) rd_idx(1) flags(1)
+     * mem_size(2) rd_value(8) mem_addr(8) mem_value(8). */
+    le64(rec + 0,  pc);
+    le32(rec + 8,  opcode);
+    rec[12] = rd_idx;
+    rec[13] = flags;
+    le16(rec + 14, mem_size);
+    le64(rec + 16, rd_val);
+    le64(rec + 24, mem_addr);
+    le64(rec + 32, mem_val);
+}
